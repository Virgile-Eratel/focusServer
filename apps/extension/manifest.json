{
  "manifest_version": 3,
  "name": "FocusServer",
  "description": "FocusServer extension",
  "version": "0.0.1",
  "action": {
    "default_popup": "hello.html",
    "default_title": "FocusServer",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://localhost:5959/*"
  ]
}
