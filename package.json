{
  "name": "focusServer",
  "private": true,
  "packageManager": "pnpm@10.2.1",
  "author": "Virgile Eratel",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @focus/shared build && pnpm --filter @focus/shared --filter @focus/server run dev",
    "build:server": "pnpm --filter @focus/shared build && pnpm --filter @focus/server build",
    "build:extension": "pnpm --filter @focus/shared build && pnpm --filter @focus/extension build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:server": "pnpm --filter @focus/server test"
  },
  "devDependencies": {
    "prettier": "^3.7.3"
  }
}
